{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "strict": true,
    "types": ["node", "mocha"],
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "sdk/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts"
  ]
}
